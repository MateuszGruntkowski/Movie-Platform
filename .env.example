# Default credentials for local Docker development.
# You don't need to change these unless you have port conflicts.

# ==========================================
# EXTERNAL APIs (REQUIRED)
# ==========================================
# You MUST provide your own API key for TMDB.
# Get it for free at: https://www.themoviedb.org/settings/api
TMDB_API_KEY=

POSTGRES_DB=movies_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_PORT=5432
DB_CONTAINER_NAME=movies_postgres

ADMINER_PORT=8088

# Default secret for development. Change this in production!
# You can leave it as is for local testing.
JWT_SECRET=myVerySecureSecretKey1234567890abcdefghijklmnopqrstuvwxyz

